# Local working output — keep the build-vault render and scratch output local.
# (data/content.json is a curated starter syllabus and IS committed;
#  learning-vault/ holds the authored lessons and IS committed.)
/vault/
/output/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Env / secrets
.env

# OS / editor
.DS_Store

# Local tool cache (mermaid-cli + headless Chrome) — never commit
.toolcache/

# claude-obsidian plugin runtime scratch — keep the wiki/ layer and the committed
# config (.vault-meta/mode.json, .vault-meta/auto-commit.disabled), ignore the rest.
.vault-meta/hook.log
.vault-meta/transport.json
.vault-meta/*.lock
.vault-meta/locks/
.vault-meta/bm25/
.vault-meta/chunks/
.raw/
