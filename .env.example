# Copy to .env and adjust. Nothing here is secret.

# Write notes straight into your real Obsidian vault instead of ./vault.
# (The CLI `--vault-path` flag overrides this per run.)
# DE_VAULT_PATH=/Users/you/Obsidian/DataEngineering

# Number of keyword tags attached to each note (default 6).
# DE_MAX_TAGS=6

# Number of "Related" notes surfaced per note (default 5).
# DE_MAX_RELATED=5
